{"cells": [{"metadata": {},"cell_type": "markdown","source": ["# Churn Analysis\n\nThis notebook provides an analysis of customer churn using PySpark."]},{"metadata": {},"cell_type": "code","source": ["from pyspark.sql import SparkSession\n\n# Initialize Spark Session\n\nspark = SparkSession.builder.appName('ChurnAnalysis').getOrCreate()\n\n# Load data\ndata = spark.read.csv('data/customer_data.csv', header=True, inferSchema=True)\n\n# Display the data\ndata.show()\n\n# Feature Engineering\n\n# Example: Creating a feature for customer age\ndata = data.withColumn('customer_age', 2026 - data['birth_year'])\n\n# Show updated DataFrame\ndata.show()"]}]}