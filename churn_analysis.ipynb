## ⚙️ Feature Engineering
from pyspark.sql.functions import when, col

df = df.withColumn(
    "TenureGroup",
    when(col("tenure") < 12, "0-1 Year")
    .when(col("tenure") < 24, "1-2 Years")
    .otherwise("2+ Years")
)

